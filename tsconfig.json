{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "tests/**/*.ts",
    "pages/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
